# Copy this file to .env (project root) and fill in real values.
# setup_and_run.ps1 will create .env for you interactively if it's missing --
# you only need to edit this by hand if you're doing it manually.
#
# Only ONE of ANTHROPIC_API_KEY / GROQ_API_KEY is required for the LLM
# features (chat, "Why this?" explanations, cold-start onboarding) to work.
# Everything else is optional -- the app degrades gracefully without it.

# Preferred if set (paid). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Free-tier fallback, used if ANTHROPIC_API_KEY isn't set. Get one at
# https://console.groq.com
GROQ_API_KEY=

# Poster/plot/cast enrichment. Free at https://www.omdbapi.com/apikey.aspx
# Comma-separate multiple keys to rotate on the 1,000/day free quota.
OMDB_API_KEY=

# Optional -- traces every LLM call for cost/latency/input-output inspection.
# Get keys at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
